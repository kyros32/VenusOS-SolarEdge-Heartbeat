#!/bin/bash
packageLogFile="/var/log/SolarEdgeHeartbeat/current"

source "/data/SetupHelper/HelperResources/IncludeHelpers"

packageAction() {
    case $1 in
        INSTALL)
            logMessage "Installing SolarEdge Heartbeat Service..."
            # SetupHelper natively looks for the "service" folder and installs it
            installService $packageName

            logMessage "Patching QML UI..."
            cp "$scriptDir/qml/PageSolarEdge.qml" "$qmlDir/"
            
            # Inject menu item into Settings page safely
            sed -i '/description: qsTr("Display & language")/a \ \ \ \ \ \ \ \ MbSubMenu { description: qsTr("SolarEdge Heartbeat"); subpage: Component { PageSolarEdge {} } }' "$qmlDir/PageSettings.qml"
            
            restartGui=true
            ;;
            
        UNINSTALL)
            logMessage "Uninstalling SolarEdge Heartbeat..."
            removeService $packageName
            
            # Remove QML file and clean up PageSettings
            rm -f "$qmlDir/PageSolarEdge.qml"
            sed -i '/description: qsTr("SolarEdge Heartbeat")/d' "$qmlDir/PageSettings.qml"
            
            restartGui=true
            ;;
    esac
}

# --- SetupHelper Execution Block ---
if [ $scriptAction == 'NONE' ] ; then
    standardActionPrompt
else
    packageAction $scriptAction
fi

endScript
